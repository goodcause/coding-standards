<?xml version="1.0"?>
<ruleset name="GoodCause-WordPress-Default">
	<description>A default ruleset used on all Good Cause WordPress projects.</description>

	<exclude-pattern>node_modules/*</exclude-pattern>
	<exclude-pattern>vendor/*</exclude-pattern>

	<!-- Load the WordPress-Extra ruleset (includes the WordPress-Core ruleset). -->
	<rule ref="WordPress-Extra"/>

	<!-- Load the WordPress-Docs ruleset. -->
	<rule ref="WordPress-Docs"/>

	<!-- Loads the PHP Compatibility ruleset. -->
	<rule ref="PHPCompatibilityWP" />

	<!-- Set the PHP version for the PHPCompatibilityWP standard to test against. -->
	<config name="testVersion" value="7.4-"/>
	
</ruleset>
